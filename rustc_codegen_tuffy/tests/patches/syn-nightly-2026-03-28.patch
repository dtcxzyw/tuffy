+fn edition_from_manifest(path: &Path) -> Option<&'static str> {
+    let test_root = Path::new("tests/rust");
+    for dir in path.ancestors().skip(1) {
+        if !dir.starts_with(test_root) {
+            break;
+        }
+        let manifest = dir.join("Cargo.toml");
+        let Ok(contents) = fs::read_to_string(manifest) else {
+            continue;
+        };
+        for line in contents.lines() {
+            let Some((key, value)) = line.split_once('=') else {
+                continue;
+            };
+            if key.trim() != "edition" {
+                continue;
+            }
+            return match value.trim().trim_matches('"') {
+                "2015" => Some("2015"),
+                "2018" => Some("2018"),
+                "2021" => Some("2021"),
+                "2024" => Some("2024"),
+                _ => None,
+            };
+        }
+    }
+    None
+}
